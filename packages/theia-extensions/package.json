{
  "name": "@spexr/theia-extensions",
  "version": "0.0.0",
  "private": true,
  "description": "SPEXR Theia extensions (browser + electron-main)",
  "license": "MIT",
  "main": "lib/browser/index.js",
  "scripts": {
    "build": "tsc -b && pnpm copy-assets",
    "dev": "tsc -b --watch",
    "copy-assets": "node -e \"const{mkdirSync,readdirSync,copyFileSync}=require('fs');mkdirSync('lib/browser/style',{recursive:true});readdirSync('src/browser/style').filter(f=>f.endsWith('.css')).forEach(f=>copyFileSync('src/browser/style/'+f,'lib/browser/style/'+f))\"",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf lib .turbo *.tsbuildinfo"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/index",
      "electronMain": "lib/electron-main/index",
      "backend": "lib/node/index"
    }
  ],
  "dependencies": {
    "@spexr/agent": "workspace:*",
    "@spexr/core": "workspace:*",
    "@spexr/memory": "workspace:*",
    "@spexr/onboarding": "workspace:*",
    "@spexr/spec": "workspace:*",
    "@spexr/ui-kit": "workspace:*",
    "@theia/core": "^1.71.0",
    "@theia/editor": "^1.71.0",
    "@theia/electron": "^1.71.0",
    "@theia/file-search": "^1.71.0",
    "@theia/filesystem": "^1.71.0",
    "@theia/scm": "1.71.0",
    "simple-git": "^3.27.0",
    "@theia/markers": "^1.71.0",
    "@theia/messages": "^1.71.0",
    "@theia/monaco": "^1.71.0",
    "@theia/monaco-editor-core": "1.108.201",
    "@theia/navigator": "^1.71.0",
    "@theia/outline-view": "^1.71.0",
    "@theia/preferences": "^1.71.0",
    "@theia/process": "^1.71.0",
    "@theia/terminal": "^1.71.0",
    "@theia/userstorage": "^1.71.0",
    "@theia/variable-resolver": "^1.71.0",
    "@theia/workspace": "^1.71.0",
    "dompurify": "^3.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^14.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "tm-grammars": "^1.31.15"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "typescript": "^6.0.3"
  }
}
